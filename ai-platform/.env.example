# Obsidian vault — absolute path to docs/obsidian-vault/ at monorepo root.
# Required because ai-service runs from ai-platform/ (one level below the vault).
VAULT_PATH=/absolute/path/to/ai-agent-microservices/docs/obsidian-vault

# App
NODE_ENV=development
LOG_LEVEL=debug

# Service ports
API_GATEWAY_PORT=4000
AI_SERVICE_PORT=4001
AUTH_SERVICE_PORT=4002
FRONTEND_PORT=3000

# AI
AI_PROVIDER=claude
# API key: use ANTHROPIC_API_KEY (Anthropic docs) or CLAUDE_API_KEY (alias). If both are set, CLAUDE_API_KEY wins.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
# Messages API model id; see https://docs.anthropic.com/en/docs/models-overview
CLAUDE_MODEL=claude-sonnet-4-6
OLLAMA_URL=http://localhost:11434
# Must match vector dimensions in Prisma (768) — nomic-embed-text is 768-dim
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# PostgreSQL
POSTGRES_DB=ai_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_platform?schema=public"

# Kafka
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
KAFKA_BROKER=localhost:9092

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
