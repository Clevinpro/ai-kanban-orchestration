# Obsidian vault — absolute path to docs/obsidian-vault/ at monorepo root.
# Required because ai-service runs from ai-platform/ (one level below the vault).
VAULT_PATH=/absolute/path/to/ai-agent-microservices/docs/obsidian-vault

# App
NODE_ENV=development
LOG_LEVEL=debug

# Service ports
API_GATEWAY_PORT=4000
AI_SERVICE_PORT=4001
AUTH_SERVICE_PORT=4002
FRONTEND_PORT=3000

# AI
AI_PROVIDER=claude
# API key: use ANTHROPIC_API_KEY (Anthropic docs) or CLAUDE_API_KEY (alias). If both are set, CLAUDE_API_KEY wins.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
# Messages API model id; see https://docs.anthropic.com/en/docs/models-overview
CLAUDE_MODEL=claude-sonnet-4-6
OLLAMA_URL=http://localhost:11434
# Must match vector dimensions in Prisma (768) — nomic-embed-text is 768-dim
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Embedding provider — 'ollama' (default) | 'openai' | 'lmstudio' (local, OpenAI-compatible)
EMBEDDING_PROVIDER=ollama

# OpenAI provider config — required when EMBEDDING_PROVIDER=openai
# WARNING: switching provider truncates all chunks and vault documents.
# Manually uploaded documents must be re-uploaded after a provider switch.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LM Studio provider config — used when EMBEDDING_PROVIDER=lmstudio.
# No API key required. URL is the OpenAI-compatible base (include /v1).
# Model MUST output 768-dim vectors to match the vector(768) column —
# 'text-embedding-nomic-embed-text-v1.5' is native 768.
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# PostgreSQL
POSTGRES_DB=ai_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_platform?schema=public"

# Kafka
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
KAFKA_BROKER=localhost:9092

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
