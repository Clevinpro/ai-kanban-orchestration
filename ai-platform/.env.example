# Obsidian vault — absolute path to docs/obsidian-vault/ at monorepo root.
# Required because ai-service runs from ai-platform/ (one level below the vault).
VAULT_PATH=/absolute/path/to/ai-agent-microservices/docs/obsidian-vault

# App
NODE_ENV=development
LOG_LEVEL=debug

# Service ports
API_GATEWAY_PORT=4000
AI_SERVICE_PORT=4001
AUTH_SERVICE_PORT=4002
FRONTEND_PORT=3000

# Async upload (fast-upload-indexing epic): POST /api/documents/upload now
# validates + stores the document row and returns 202 Accepted immediately with
# { documentId, status: 'pending' } — indexing (context-gen + embed + insert)
# runs in the background. Poll GET /api/documents/:id/status, which returns
# { documentId, status, chunksCount } where status walks
# pending -> indexing -> ready (or failed), to know when search includes the doc.
#
# api-gateway upload proxy request timeout (ms). On timeout/abort the proxy
# returns 504 (a non-2xx downstream maps to 502) instead of hanging on a
# slow/unresponsive ai-service; the 202 + body is relayed through unchanged.
# Default 30000.
UPLOAD_PROXY_TIMEOUT_MS=30000

# AI provider — 'claude' | 'ollama' | 'lmstudio'
# This is the CHAT LLM. It is also the model used for Contextual Retrieval (see
# CONTEXTUAL_RETRIEVAL_ENABLED below) — independent of EMBEDDING_PROVIDER.
AI_PROVIDER=claude

# Contextual Retrieval — at index time an LLM (AI_PROVIDER above) writes a short
# 1-2 sentence context per chunk that situates it within its whole document; that
# context is prepended to the chunk for both embedding and lexical storage,
# improving retrieval recall.
# TRADEOFF: this adds ONE LLM call per chunk during every upload/reindex. Since
# the fast-upload-indexing epic indexing runs in the BACKGROUND (see async-upload
# note below) and each chunk's context prompt is bounded to a window
# (CONTEXT_WINDOW_CHARS) instead of the whole document, this is now safe to keep
# enabled. Set CONTEXTUAL_RETRIEVAL_ENABLED=false to index with no LLM calls
# (heading-as-context only). Default: true.
# NOTE: This epic ships with .env set to false to gate the rollout; once the
# fast-upload-indexing epic has landed and its tests pass, return it to true:
# CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXTUAL_RETRIEVAL_ENABLED=false
# Max number of chunks contextualized in parallel during a reindex. Bounds load
# on a local LLM so a full vault reindex does not overwhelm it. Default: 4.
CONTEXTUAL_RETRIEVAL_CONCURRENCY=4
# Per-chunk context prompt window (chars). Instead of re-sending the whole
# document with every chunk (O(chunks x documentLength)), the context LLM call
# uses a bounded window of this many chars centred on the chunk
# (O(chunks x window)). When a document already fits in the window the whole
# document is used (behaviour unchanged for small docs). Default: 2000.
CONTEXT_WINDOW_CHARS=2000
# Per-chunk context-generation LLM timeout (ms). If one chunk's context call
# exceeds this, it falls back to heading-context (logged warn) instead of
# stalling the whole document index. Default: 15000.
CONTEXT_LLM_TIMEOUT_MS=15000
# API key: use ANTHROPIC_API_KEY (Anthropic docs) or CLAUDE_API_KEY (alias). If both are set, CLAUDE_API_KEY wins.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
# Messages API model id; see https://docs.anthropic.com/en/docs/models-overview
CLAUDE_MODEL=claude-sonnet-4-6
OLLAMA_URL=http://localhost:11434
# Chat model id; blank auto-picks the running model (/api/ps), then the first
# installed model (/api/tags), then falls back to llama3.2.
OLLAMA_CHAT_MODEL=qwen3.6
# Embedding model — MUST emit 1024-dim vectors to match the vector(1024) column.
# bge-m3 is multilingual (Ukrainian-capable) and 1024-dim. Pull it before boot:
#   ollama pull bge-m3
OLLAMA_EMBEDDING_MODEL=bge-m3

# LM Studio chat provider — used when AI_PROVIDER=lmstudio. No API key required.
# URL is the OpenAI-compatible base (include /v1). Leave LMSTUDIO_CHAT_MODEL blank
# to auto-pick the first model loaded in LM Studio, or pin a specific id.
# The loaded model must be a chat/instruct model — an embedding model will fail
# /chat/completions.
LMSTUDIO_CHAT_URL=http://localhost:1234/v1
LMSTUDIO_CHAT_MODEL=qwen3.6-35b-a3b-ud-mlx

# Embedding provider — 'ollama' (default) | 'openai' | 'lmstudio' (local, OpenAI-compatible)
# ALL providers must emit 1024-dim vectors to match the vector(1024) column.
# The default models below are 1024-dim multilingual (Ukrainian-capable).
EMBEDDING_PROVIDER=ollama

# OpenAI provider config — required when EMBEDDING_PROVIDER=openai
# WARNING: changing the embedding provider OR model truncates all chunks and vault
# documents; the vault re-indexes automatically on next boot. Manually uploaded
# documents must be re-uploaded after such a change.
# The OpenAI path requests dimensions: 1024 (Matryoshka truncation) so the
# returned vectors fit the vector(1024) column.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LM Studio provider config — used when EMBEDDING_PROVIDER=lmstudio.
# No API key required. URL is the OpenAI-compatible base (include /v1).
# Model MUST output 1024-dim vectors to match the vector(1024) column.
# bge-m3 is multilingual (Ukrainian-capable) and 1024-dim. It MUST be loaded in
# LM Studio BEFORE ai-service boots.
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_EMBEDDING_MODEL=bge-m3

# PostgreSQL
POSTGRES_DB=ai_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_platform?schema=public"

# Kafka
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
KAFKA_BROKER=localhost:9092

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
