{
  "name": "@ai-platform/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many --target=serve --projects=api-gateway,auth-service,ai-service --parallel=3",
    "lint": "nx run-many --target=lint && npm run typecheck",
    "lint:fix": "nx run-many --target=lint --fix && npm run typecheck",
    "typecheck": "nx run-many --target=typecheck",
    "test": "nx run-many --target=test",
    "test:cov": "nx run-many --target=test --coverage",
    "prepare": "husky",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
