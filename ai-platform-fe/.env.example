# Copy to `.env` in this folder (`ai-platform-fe/`) and adjust.
# Nx loads these when running serve/build; `NX_PUBLIC_*` is inlined into the browser bundle (Rspack).

# API base URL including the gateway global prefix `/api` (no trailing slash).
# Example routes: `{NX_PUBLIC_API_URL}/auth/login`, `{NX_PUBLIC_API_URL}/documents`, …
NX_PUBLIC_API_URL=http://localhost:4000/api
